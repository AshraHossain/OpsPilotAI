# ─── LLM Selection ────────────────────────────────────────────────────────────
# To use local Ollama:  ollama/gemma4:26b
# To use Gemini:        gemini/gemini-2.5-flash
# To use OpenRouter:    openrouter/anthropic/claude-3.5-sonnet
AGENT_MODEL=ollama/gemma4:26b

# ─── OpenRouter ──────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-...

# ─── Kimi / Moonshot AI ──────────────────────────────────────────────────────
# Models: moonshot/moonshot-v1-8k | moonshot-v1-32k | moonshot-v1-128k
# To use: AGENT_MODEL=moonshot/moonshot-v1-32k
MOONSHOT_API_KEY=sk-...

# ─── Google Gemini ───────────────────────────────────────────────────────────
GOOGLE_API_KEY=your_google_api_key_here

# ─── Ollama (Local) ──────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# ─── GitHub ──────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_...
GITHUB_WEBHOOK_SECRET=your_webhook_secret

# ─── Kubernetes ──────────────────────────────────────────────────────────────
KUBECONFIG=/home/user/.kube/config   # or leave blank for in-cluster config
K8S_NAMESPACE=default

# ─── Prometheus ──────────────────────────────────────────────────────────────
PROMETHEUS_URL=http://prometheus:9090
ALERTMANAGER_URL=http://alertmanager:9093

# ─── AWS ─────────────────────────────────────────────────────────────────────
AWS_DEFAULT_REGION=us-east-1
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...

# ─── App ─────────────────────────────────────────────────────────────────────
APP_ENV=development          # development | staging | production
LOG_LEVEL=INFO
APPROVAL_GATE_ENABLED=true   # require human approval for destructive actions
